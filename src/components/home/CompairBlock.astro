---
---

<section class="w-full bg-[#f0f6fb] py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">
        Kodėl Vecticum?
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-500">
        Palyginkite darbo su Vecticum ir be jo skirtumus – ir pamatykite, kodėl šimtai organizacijų renkasi mus kasdieniam efektyvumui.
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Be Vecticum -->
        <div class="p-8 sm:p-10 lg:border-r border-gray-100">
          <div class="flex items-center gap-3 mb-7">
            <div class="w-10 h-10 rounded-full bg-red-50 border border-red-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 11-12.728 12.728 9 9 0 0112.728-12.728zM15 9l-6 6m0-6l6 6"/></svg>
            </div>
            <div>
              <p class="text-base font-bold text-gray-900">Įprastas būdas</p>
              <p class="text-xs text-gray-400">Be sistemos automatizacijos</p>
            </div>
          </div>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-gray-600 text-[15px] py-2.5 px-4 rounded-xl bg-red-50/50 border border-red-100/50">
              <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Lėti įmonės procesai
            </li>
            <li class="flex items-center gap-3 text-gray-600 text-[15px] py-2.5 px-4 rounded-xl bg-red-50/50 border border-red-100/50">
              <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Didelė klaidų tikimybė
            </li>
            <li class="flex items-center gap-3 text-gray-600 text-[15px] py-2.5 px-4 rounded-xl bg-red-50/50 border border-red-100/50">
              <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Daug rankinio ir pasikartojančio darbo
            </li>
            <li class="flex items-center gap-3 text-gray-600 text-[15px] py-2.5 px-4 rounded-xl bg-red-50/50 border border-red-100/50">
              <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Netvarkinga dokumentacija
            </li>
            <li class="flex items-center gap-3 text-gray-600 text-[15px] py-2.5 px-4 rounded-xl bg-red-50/50 border border-red-100/50">
              <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              Dabartinė sistema nėra lanksti
            </li>
          </ul>
        </div>

        <!-- Su Vecticum -->
        <div class="p-8 sm:p-10 bg-[#3C7099]">
          <div class="flex items-center gap-3 mb-7">
            <div class="w-10 h-10 rounded-full bg-white/15 border border-white/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="text-base font-bold text-white">Su Vecticum</p>
              <p class="text-xs text-white/50">Išmanus sprendimas</p>
            </div>
          </div>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-white text-[15px] py-2.5 px-4 rounded-xl bg-white/10 border border-white/10">
              <svg class="w-4 h-4 text-emerald-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              Pilnai pritaikyti sprendimai Jūsų poreikiams
            </li>
            <li class="flex items-center gap-3 text-white text-[15px] py-2.5 px-4 rounded-xl bg-white/10 border border-white/10">
              <svg class="w-4 h-4 text-emerald-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              Plačiausias rinkoje sprendimų pasirinkimas
            </li>
            <li class="flex items-center gap-3 text-white text-[15px] py-2.5 px-4 rounded-xl bg-white/10 border border-white/10">
              <svg class="w-4 h-4 text-emerald-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              Visi verslo procesai vienoje sistemoje
            </li>
            <li class="flex items-center gap-3 text-white text-[15px] py-2.5 px-4 rounded-xl bg-white/10 border border-white/10">
              <svg class="w-4 h-4 text-emerald-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              Mažesnės įmonės išlaidos
            </li>
            <li class="flex items-center gap-3 text-white text-[15px] py-2.5 px-4 rounded-xl bg-white/10 border border-white/10">
              <svg class="w-4 h-4 text-emerald-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              Saugumas ir atsekamumas
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
