---
import Hero from "../components/home/Hero.astro";
import BlogPreview from "../components/blog/BlogPreview.astro";
import ClientsLogo from "../components/home/ClientsLogo.astro";
import Services from "../components/home/Services.astro";
import ContactForm from "../components/home/ContactForm.astro";
import MainLayout from "../layouts/MainLayout.astro";
import CompairBlock from "../components/home/CompairBlock.astro";
import SecurityStandards from "../components/home/SecurityStandards.astro";
import Testimonials from "../components/home/Testimonials.astro";
import VideoShowcase from "../components/home/VideoShowcase.astro";

const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Kas yra Vecticum?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Vecticum – tai lanksti verslo valdymo sistema, skirta automatizuoti įvairius procesus: nuo atostogų ar sąskaitų tvirtinimo iki individualių, įmonei pritaikytų sprendimų. Ji leidžia centralizuotai valdyti dokumentus, užtikrina saugumą, sklandų darbuotojų darbą ir lengvą pritaikomumą tiek mažoms, tiek didelėms organizacijoms."
          }
        },
        {
          "@type": "Question",
          "name": "Kokia yra Vecticum kaina?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Vecticum siūlo lanksčius kainų planus, pritaikytus pagal įmonės darbuotojų skaičių ir pasirinktų sprendimų apimtį. Norėdami gauti individualų pasiūlymą, kviečiame užpildyti užklausos formą arba susisiekti su mūsų komanda."
          }
        },
        {
          "@type": "Question",
          "name": "Kaip išbandyti Vecticum?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Norėdami išbandyti Vecticum, užpildykite registracijos formą – mūsų komanda su Jumis susisieks ir pasirūpins demonstracija bei išbandymo galimybe, atsižvelgiant į Jūsų poreikius."
          }
        },
        {
          "@type": "Question",
          "name": "Kaip greitai paleidžiama Vecticum sistema?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Standartinių sprendimų paleidimas gali užtrukti iki vienos valandos. Kiekvienos įmonės paleidimo procesas derinamas individualiai, atsižvelgiant į pasirinktų modulių skaičių ir organizacijos vidinius procesus."
          }
        },
        {
          "@type": "Question",
          "name": "Ar Vecticum tinkamas mažoms ir vidutinėms įmonėms?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Taip, Vecticum yra lanksti platforma, tinkama tiek mažoms, tiek vidutinėms ar didelėms organizacijoms. Sprendimai lengvai pritaikomi pagal individualius verslo poreikius."
          }
        },
        {
          "@type": "Question",
          "name": "Ar Vecticum gali naudotis užsienio įmonės ar darbuotojai?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Taip, Vecticum palaiko kelias kalbas – sistema prieinama anglų, lietuvių, rusų, lenkų ir latvių kalbomis, todėl ją gali lengvai naudoti ir tarptautinės komandos."
          }
        }
      ]
    }
  ]
});

---

<MainLayout
  title="Personalo ir dokumentų valdymo sistema | Vecticum"
  description="VECTICUM – dokumentų, sąskaitų ir personalo valdymo sistema. Automatizuokite verslo procesus: atostogas, užduotis, sutartis ir daugiau. Išbandykite nemokamai!"
  image="/media/og-default.webp"
  schema={organizationSchema}
>
  <Hero />
    <ClientsLogo />
    <Services />

  <!-- Kainos CTA -->
  <section class="w-full bg-[#3C7099]">
    <div class="max-w-5xl mx-auto px-4 py-12 sm:py-14 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="text-center sm:text-left">
        <h2 class="text-xl sm:text-2xl font-bold text-white">Norite sužinoti pasirinkto sprendimo kainą?</h2>
        <p class="mt-2 text-white/80 text-sm sm:text-base">Susisiekite ir gaukite pasiūlymą, pritaikytą jūsų įmonei</p>
      </div>
      <a href="/registracijademo" class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-[#3C7099] font-semibold rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200 whitespace-nowrap">
        Sužinoti kainą
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

    <VideoShowcase />
    <Testimonials />
    <CompairBlock />
    <SecurityStandards />

  <!-- DUK section -->
  <section class="w-full px-4 py-16 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-900 text-center mb-12">Dažnai užduodami klausimai</h2>

      <div class="space-y-4">
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kas yra Vecticum?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Vecticum – tai lanksti verslo valdymo sistema, skirta automatizuoti įvairius procesus: nuo atostogų ar sąskaitų tvirtinimo iki individualių, įmonei pritaikytų sprendimų. Ji leidžia centralizuotai valdyti dokumentus, užtikrina saugumą, sklandų darbuotojų darbą ir lengvą pritaikomumą tiek mažoms, tiek didelėms organizacijoms.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kokia yra Vecticum kaina?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Vecticum siūlo lanksčius kainų planus, pritaikytus pagal įmonės darbuotojų skaičių ir pasirinktų sprendimų apimtį. Norėdami gauti individualų pasiūlymą, kviečiame užpildyti užklausos formą arba susisiekti su mūsų komanda.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kaip išbandyti Vecticum?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Norėdami išbandyti Vecticum, užpildykite registracijos formą – mūsų komanda su Jumis susisieks ir pasirūpins demonstracija bei išbandymo galimybe, atsižvelgiant į Jūsų poreikius.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kaip greitai paleidžiama Vecticum sistema?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Standartinių sprendimų paleidimas gali užtrukti iki vienos valandos. Kiekvienos įmonės paleidimo procesas derinamas individualiai, atsižvelgiant į pasirinktų modulių skaičių ir organizacijos vidinius procesus.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Ar Vecticum tinkamas mažoms ir vidutinėms įmonėms?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Taip, Vecticum yra lanksti platforma, tinkama tiek mažoms, tiek vidutinėms ar didelėms organizacijoms. Sprendimai lengvai pritaikomi pagal individualius verslo poreikius.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Ar Vecticum gali naudotis užsienio įmonės ar darbuotojai?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Taip, Vecticum palaiko kelias kalbas – sistema prieinama anglų, lietuvių, rusų, lenkų ir latvių kalbomis, todėl ją gali lengvai naudoti ir tarptautinės komandos.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
  <BlogPreview />
</MainLayout>
