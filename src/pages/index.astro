---
import Hero from "../components/home/Hero.astro";
import BlogPreview from "../components/blog/BlogPreview.astro";
import ClientsLogo from "../components/home/ClientsLogo.astro";
import Services from "../components/home/Services.astro";
import ContactForm from "../components/home/ContactForm.astro";
import MainLayout from "../layouts/MainLayout.astro";
import CompairBlock from "../components/home/CompairBlock.astro";
import SecurityStandards from "../components/home/SecurityStandards.astro";
import Testimonials from "../components/home/Testimonials.astro";
import VideoShowcase from "../components/home/VideoShowcase.astro";

const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://vecticum.lt/#organization",
      "name": "Vecticum",
      "url": "https://vecticum.lt",
      "logo": "https://vecticum.lt/_astro/logo.BmXpwNHg.webp",
      "email": "info@vecticum.com",
      "telephone": "+37069605332",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "T. Kosciuškos g. 24",
        "addressLocality": "Vilnius",
        "postalCode": "01100",
        "addressCountry": "LT"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+37069605332",
        "contactType": "sales",
        "areaServed": ["LT", "PL", "GB"]
      }
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://vecticum.lt/#software",
      "name": "Vecticum",
      "url": "https://vecticum.lt",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Dokumentų, sąskaitų ir personalo valdymo sistema vienoje vietoje.",
      "publisher": {
        "@id": "https://vecticum.lt/#organization"
      },
      "offers": {
        "@type": "Offer",
        "url": "https://vecticum.lt/personalo-valdymo-sprendimu-planai"
      }
    }
  ]
});
---

<MainLayout
  title="Personalo ir dokumentų valdymo sistema | Vecticum"
  description="VECTICUM – dokumentų, sąskaitų ir personalo valdymo sistema. Automatizuokite verslo procesus: atostogas, užduotis, sutartis ir daugiau. Išbandykite nemokamai!"
  image="/media/og-default.webp"
  schema={organizationSchema}
>
  <Hero />
    <ClientsLogo />
    <Services />
    <VideoShowcase />
    <Testimonials />
    <CompairBlock />
    <SecurityStandards />

  <!-- DUK section -->
  <section class="w-full px-4 py-16 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-900 text-center mb-12">Dažnai užduodami klausimai</h2>

      <div class="space-y-4">
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kas yra Vecticum?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Vecticum – tai lanksti verslo valdymo sistema, skirta automatizuoti įvairius procesus: nuo atostogų ar sąskaitų tvirtinimo iki individualių, įmonei pritaikytų sprendimų. Ji leidžia centralizuotai valdyti dokumentus, užtikrina saugumą, sklandų darbuotojų darbą ir lengvą pritaikomumą tiek mažoms, tiek didelėms organizacijoms.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kokia yra Vecticum kaina?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Vecticum siūlo lanksčius kainų planus, pritaikytus pagal įmonės darbuotojų skaičių ir pasirinktų sprendimų apimtį. Norėdami gauti individualų pasiūlymą, kviečiame užpildyti užklausos formą arba susisiekti su mūsų komanda.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kaip išbandyti Vecticum?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Norėdami išbandyti Vecticum, užpildykite registracijos formą – mūsų komanda su Jumis susisieks ir pasirūpins demonstracija bei išbandymo galimybe, atsižvelgiant į Jūsų poreikius.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Kaip greitai paleidžiama Vecticum sistema?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Standartinių sprendimų paleidimas gali užtrukti iki vienos valandos. Kiekvienos įmonės paleidimo procesas derinamas individualiai, atsižvelgiant į pasirinktų modulių skaičių ir organizacijos vidinius procesus.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Ar Vecticum tinkamas mažoms ir vidutinėms įmonėms?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Taip, Vecticum yra lanksti platforma, tinkama tiek mažoms, tiek vidutinėms ar didelėms organizacijoms. Sprendimai lengvai pritaikomi pagal individualius verslo poreikius.</p>
            </div>
          </details>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-6 text-lg font-semibold text-gray-900 hover:bg-gray-50 transition-colors duration-200">
              <span>Ar Vecticum gali naudotis užsienio įmonės ar darbuotojai?</span>
              <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100">
              <p class="pt-4">Taip, Vecticum palaiko kelias kalbas – sistema prieinama anglų, lietuvių, rusų, lenkų ir latvių kalbomis, todėl ją gali lengvai naudoti ir tarptautinės komandos.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
  <BlogPreview />
</MainLayout>
