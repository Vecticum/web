---
import MainLayout from "../layouts/MainLayout.astro";

const seoTitle = "Vebinaras: Vidaus norminių dokumentų valdymas | Vecticum";
const seoDescription =
  "Trumpa registracijos forma į Vecticum vebinarą apie vidaus norminių dokumentų valdymą.";
const seoImage = "/media/services/tvarkos-valdymas-hero.webp";
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImage} noIndex={true}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-[#3C7099] py-20 px-4 sm:px-6 lg:px-8">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-white/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-white/90 text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/></svg>
        Nemokamas vebinaras
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
        Kviečiame į nemokamą VECTICUM vebinarą
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Kaip užtikrinti, kad darbuotojai laiku susipažintų su aktualiomis vidaus tvarkomis, įsakymais ir taisyklėmis? Nemokamame vebinare parodysime, kaip su VECTICUM galite valdyti vidaus norminius dokumentus: nuo tvarkų iki darbuotojų žinių patikrinimo.
      </p>
      </p>
    </div>
  </section>

  <!-- Form -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-[#f4f7fa] to-white">
    <div class="max-w-3xl mx-auto">
      <div class="rounded-2xl border border-gray-100 bg-white p-8 sm:p-10 shadow-lg">
        <h2 class="text-2xl font-bold text-gray-900 text-center">Registracija į vebinarą</h2>

        <form id="webinar-registration-form" class="mt-7 space-y-5">
            <input
              type="hidden"
              name="form_source"
              value="Leads iš naujienlaiškio: Vidaus norminių dokumentų valdymo vebinaras"
            />
            <input type="hidden" name="newsletterConsent" value="false" data-newsletter-consent />

            <div style="position: absolute; left: -5000px;" aria-hidden="true">
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div>
              <label for="company" class="mb-1 block text-sm font-medium text-gray-700">Įmonės pavadinimas*</label>
              <input
                id="company"
                name="company"
                type="text"
                required
                autocomplete="organization"
                class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#C81E6A] focus:border-transparent transition duration-200 hover:border-[#C81E6A]/50"
                placeholder="Pvz., UAB Pavyzdys"
              />
              <p id="company-error" class="mt-1 hidden text-xs text-red-600">Įveskite įmonės pavadinimą.</p>
            </div>

            <div>
              <label for="email" class="mb-1 block text-sm font-medium text-gray-700">El. paštas*</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#C81E6A] focus:border-transparent transition duration-200 hover:border-[#C81E6A]/50"
                placeholder="pvz@imone.lt"
              />
              <p id="email-error" class="mt-1 hidden text-xs text-red-600">Įveskite teisingą el. paštą.</p>
              <p class="mt-1.5 text-xs text-gray-400">Jūsų el. paštą naudosime tik su šiuo vebinaru susijusiai informacijai. Jokiai kitai reklamai ar trečiosioms šalims jo neperduosime.</p>
            </div>

            <button
              id="submit-button"
              type="submit"
              class="w-full rounded-full bg-[#C81E6A] px-6 py-3 text-base font-semibold text-white transition hover:bg-[#a51856] focus:outline-none focus:ring-2 focus:ring-[#C81E6A]/35 shadow-md hover:shadow-lg"
            >
              Registruotis į vebinarą
            </button>
          </form>

          <div id="form-message" class="mt-5 hidden rounded-xl px-4 py-3 text-sm"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="px-4 pb-20 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto space-y-6">
      <div class="rounded-2xl bg-[#3C7099] p-6 text-white">
        <h3 class="text-lg font-bold">Vebinaro informacija</h3>
        <ul class="mt-3 space-y-1 text-sm leading-6 text-white/95">
          <li><strong>Data:</strong> liepos 16 d.</li>
          <li><strong>Laikas:</strong> 15:00 val. - 15:45 val.</li>
          <li><strong>Vieta:</strong> nuotolinis pristatymas</li>
          <li><strong>Kaina:</strong> nemokama</li>
        </ul>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white p-6 sm:p-8 shadow-sm">
        <h3 class="text-xl font-bold text-gray-900">Vebinaro metu pristatysime:</h3>
        <ul class="mt-4 space-y-2.5 text-sm leading-6 text-gray-600">
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip rengiami, derinami ir tvirtinami vidaus dokumentai;</span>
          </li>
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip organizuojamas darbuotojų supažindinimas su dokumentais;</span>
          </li>
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip VECTICUM nustato, su kokiais dokumentais turi susipažinti konkretus darbuotojas;</span>
          </li>
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip užtikrinama, kad darbuotojai susipažintų su aktualiomis dokumentų redakcijomis;</span>
          </li>
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip automatizuojama susipažinimo būklės kontrolė;</span>
          </li>
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip veikia dokumentų versijų kontrolė ir pakartotinis supažindinimas;</span>
          </li>
          <li class="flex gap-2.5">
            <svg class="mt-1 h-4 w-4 flex-shrink-0 text-[#C81E6A]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>kaip organizuojami mokymai, interaktyvūs mokymai, SCORM turinys ir testavimas.</span>
          </li>
        </ul>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white p-6 sm:p-8 shadow-sm">
        <h3 class="text-xl font-bold text-gray-900">Kam aktualus šis vebinaras?</h3>
        <div class="mt-4 space-y-4 text-sm leading-6 text-gray-600">
          <p>Vebinaras naudingas organizacijoms, kurios valdo vidaus tvarkas, darbo saugos ir sveikatos dokumentus, įsakymus, lygių galimybių, konfidencialumo, pareigybines ar kitas darbuotojams privalomas taisykles ir nori aiškiai matyti, ar darbuotojai su jomis susipažino.</p>
          <p>Tai ypač aktualu personalo, dokumentų valdymo, teisės, atitikties, darbų saugos specialistams ir vadovams, kuriems svarbu ne tik išsiųsti dokumentą, bet ir turėti kontroliuojamą, atsekamą bei patikimą procesą.</p>
        </div>
      </div>
    </div>
  </section>


  <script is:inline>
    (function () {
      if (window.webinarRegistrationInitialized) return;
      window.webinarRegistrationInitialized = true;

      const form = document.getElementById('webinar-registration-form');
      if (!form) return;

      const companyInput = form.querySelector('#company');
      const emailInput = form.querySelector('#email');
      const submitButton = form.querySelector('#submit-button');
      const companyError = form.querySelector('#company-error');
      const emailError = form.querySelector('#email-error');
      const formMessage = document.getElementById('form-message');
      const consentField = form.querySelector('[data-newsletter-consent]');

      const showMessage = (type, text) => {
        if (!formMessage) return;
        formMessage.classList.remove('hidden', 'bg-green-100', 'text-green-800', 'border', 'border-green-300', 'bg-red-100', 'text-red-800', 'border-red-300');
        if (type === 'success') {
          formMessage.classList.add('bg-green-100', 'text-green-800', 'border', 'border-green-300');
        } else {
          formMessage.classList.add('bg-red-100', 'text-red-800', 'border', 'border-red-300');
        }
        formMessage.textContent = text;
      };

      const validate = () => {
        let isValid = true;
        const company = companyInput?.value.trim() ?? '';
        const email = emailInput?.value.trim() ?? '';
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        companyError?.classList.add('hidden');
        emailError?.classList.add('hidden');
        companyInput?.classList.remove('border-red-500');
        emailInput?.classList.remove('border-red-500');

        if (!company) {
          isValid = false;
          companyError?.classList.remove('hidden');
          companyInput?.classList.add('border-red-500');
        }

        if (!email || !emailRegex.test(email)) {
          isValid = false;
          emailError?.classList.remove('hidden');
          emailInput?.classList.add('border-red-500');
        }

        return isValid;
      };

      let isSubmitting = false;

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (isSubmitting) return;

        if (!validate()) return;

        const honeypot = form.querySelector('[name="website"]');
        if (honeypot && honeypot.value) {
          showMessage('success', 'Ačiū! Jūsų registracija priimta.');
          return;
        }

        isSubmitting = true;
        submitButton.disabled = true;
        submitButton.textContent = 'Siunčiama...';
        formMessage?.classList.add('hidden');

        const company = companyInput.value.trim();
        const email = emailInput.value.trim();

        const payload = {
          name: company,
          company,
          email,
          message: 'Registracija į vebinarą: Vidaus norminių dokumentų valdymas.',
          source: 'Naujienlaiškio',
          form_source: 'Leads iš naujienlaiškio: Vidaus norminių dokumentų valdymo vebinaras',
          newsletterConsent: consentField?.value === 'true'
        };

        let recaptchaToken = 'dev-mode-token';
        try {
          if (typeof grecaptcha !== 'undefined') {
            recaptchaToken = await grecaptcha.execute('6LcP6_ArAAAAAGeVnrM_7mlRq2cjrC6l4Xifj0qQ', { action: 'webinar_registration' });
          }
        } catch (err) {
          console.warn('reCAPTCHA nepavyko, tęsiama su atsarginiu režimu.', err);
        }

        try {
          const response = await fetch('/api/crm', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Recaptcha-Token': recaptchaToken
            },
            body: JSON.stringify(payload)
          });

          const isSoftSuccess = response.ok || response.status === 502 || response.status === 503 || response.status === 504;
          if (!isSoftSuccess) {
            throw new Error('Nepavyko pateikti formos');
          }

          form.reset();
          showMessage('success', 'Ačiū! Jūsų registracija sėkminga. Likusią informaciją ir prisijungimo nuorodą atsiųsime el. paštu likus kelioms dienoms iki vebinaro.');
        } catch (error) {
          console.error(error);
          showMessage('error', 'Įvyko klaida. Bandykite dar kartą po kelių minučių.');
        } finally {
          isSubmitting = false;
          submitButton.disabled = false;
          submitButton.textContent = 'Registruotis į vebinarą';
        }
      });

      companyInput?.addEventListener('input', () => {
        companyError?.classList.add('hidden');
        companyInput.classList.remove('border-red-500');
      });

      emailInput?.addEventListener('input', () => {
        emailError?.classList.add('hidden');
        emailInput.classList.remove('border-red-500');
      });
    })();
  </script>
</MainLayout>
