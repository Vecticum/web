---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { Image } from "astro:assets";
import seoImage from "~/assets/images/logo.webp";

import dussmann from '/src/assets/media/dussmann.jpg';
import iki from '/src/assets/media/iki.png';
import civinity from '/src/assets/media/civinity.png';
import autojuta from '/src/assets/media/Autojuta.png';
import perlas from '/src/assets/media/Perlas.png';
import vilkyskiu from '/src/assets/media/VilkyskiuPienine.png';
import linasAgro from '/src/assets/media/Linas_agro.png';
import omberg from '/src/assets/media/Omberg.png';
import modus from '/src/assets/media/ModusGroup.png';
import nokia from '/src/assets/media/nokia.png';
import cgates from '/src/assets/media/Cgates.png';
import citybee from '/src/assets/media/CityBee.png';
import cargoGo from '/src/assets/media/Cargo_Go.jpg';
import airGuru from '/src/assets/media/air_guru.jpg';
import narbutas from '/src/assets/media/NARBUTAS.png';
import aradas from '/src/assets/media/Aradas.png';
import garantGroup from '/src/assets/media/GarantGroup.png';
import altaMedica from '/src/assets/media/AltaMedica.png';
import homanit from '/src/assets/media/Homanit.png';
import retal from '/src/assets/media/retal.png';
import manaRanga from '/src/assets/media/ManaRanga.png';
import projektana from '/src/assets/media/Projektana.png';
import bpo from '/src/assets/media/bpo.png';
import neogroup from '/src/assets/media/Neogroup.jpg';
import vilniausApsvietimas from '/src/assets/media/VilniausApsvietimas.png';
import trinitiJurex from '/src/assets/media/TrinitiJurex.png';
import yukon from '/src/assets/media/Yukon.png';
import freda from '/src/assets/media/Freda.png';
import garant from '/src/assets/media/GarantGroup.png';
import bnm from '/src/assets/media/BNMfinance.png';

import woodline from '/src/assets/media/woodline.png';

 
const logos = [
  dussmann, iki, civinity, autojuta, perlas, vilkyskiu, linasAgro, omberg,
  modus, nokia, cgates, citybee, cargoGo, airGuru, narbutas, aradas,
  garantGroup, altaMedica, homanit, retal, manaRanga, projektana, bpo,
  neogroup, vilniausApsvietimas, trinitiJurex, yukon, freda, garant, bnm
];

const recommendations = await getCollection("recomendations");
export const prerender = true;

const partner = [
  { 
    src: "/media/partners/infotek.png", 
    href: "https://www.infotec.lt/", 
    alt: "INFO-TEC", 
    subtitle: "Dokumentų atpažinimas ir duomenų surinkimas",
    description: "INFO-TEC ir VECTICUM partnerystė leidžia automatiškai atpažinti sąskaitose faktūrose ir kituose dokumentuose esančią informaciją bei iš karto panaudoti šiuos duomenis tolimesniuose verslo procesuose – dokumentų registravime, derinime, tvirtinime ir užduočių paskirstyme.",
    fullText: `<p>Dokumentai versle dažnai yra ne tik failai. Juose slypi informacija, nuo kurios priklauso tolimesni veiksmai: kas turi patvirtinti sąskaitą, kokiam tiekėjui ji priklauso, kokia suma turi būti suderinta, kokie terminai svarbūs ir kokį sprendimą reikia priimti toliau.</p>
<p>Būtent todėl organizacijoms vis svarbiau ne tik skaitmenizuoti dokumentus, bet ir užtikrinti, kad juose esantys duomenys būtų greitai, tiksliai ir patogiai panaudojami kasdieniuose procesuose. Šiam tikslui VECTICUM bendradarbiauja su <strong>INFO-TEC</strong> – vienu didžiausių dokumentų skaitmeninimo paslaugų teikėjų Lietuvoje, kuris daugiau kaip 30 metų specializuojasi dokumentų skaitmeninimo, sąskaitų faktūrų atpažinimo, dokumentų atpažinimo (OCR) ir automatinio duomenų įvedimo paslaugų srityje. Pasitelkdamas pažangias dokumentų atpažinimo technologijas ir dirbtinį intelektą, INFO-TEC <a href="https://www.infotec.lt/dokumentu-skaitmeninimo-paslaugos/saskaitu-fakturu-atpazinimas-ir-automatinis-duomenu-ivedimas/" target="_blank" rel="noopener noreferrer" class="text-[#3C7099] underline hover:text-[#2a5570]">automatizuoja sąskaitų faktūrų atpažinimą ir duomenų įvedimą</a>, sumažina rankinio duomenų suvedimo poreikį bei užtikrina aukštą duomenų kokybę.</p>
<p>INFO-TEC padeda automatiškai atpažinti sąskaitose faktūrose ir kituose dokumentuose esančią informaciją, sumažinti rankinio duomenų suvedimo poreikį bei užtikrinti didesnį duomenų tikslumą. Tuo tarpu VECTICUM leidžia šiuos duomenis panaudoti tolimesniuose verslo procesuose – dokumentų registravime, derinime, tvirtinime, užduočių paskirstyme, kontrolei ir atsekamumui.</p>
<p>Tai reiškia, kad dokumentas nebėra tik prisegtas failas ar į sistemą įkeltas PDF. Atpažinti duomenys tampa proceso dalimi: jie gali inicijuoti veiksmus, užpildyti laukus, padėti atsakingiems darbuotojams greičiau priimti sprendimus ir sumažinti pasikartojantį rankinį darbą.</p>
<p>Toks bendradarbiavimas ypač aktualus organizacijoms, kurios kasdien dirba su dideliais sąskaitų, tiekėjų dokumentų ar kitų administracinių dokumentų kiekiais. Kai informacija atpažįstama automatiškai ir iš karto patenka į valdomą procesą, darbuotojai gali mažiau laiko skirti duomenų suvedimui, paieškai ar tikrinimui, o daugiau – sprendimų priėmimui ir proceso kontrolei.</p>
<p><strong>Rezultatas</strong> – mažiau rankinio darbo, aiškesnė dokumentų eiga, geresnis atsekamumas ir daugiau kontrolės ten, kur jos labiausiai reikia kasdienėje veikloje.</p>`,
    benefits: ["Automatinis dokumentų duomenų atpažinimas", "Mažiau rankinio duomenų suvedimo", "Didesnis duomenų tikslumas", "Aiškesnė dokumentų eiga ir atsekamumas"]
  },
  { 
    src: "/media/partners/Google_cloud.png", 
    href: "https://cloud.google.com/", 
    alt: "Google Cloud", 
    subtitle: "Debesų kompiuterijos paslaugos",
    description: "Google Cloud infrastruktūra užtikrina VECTICUM sistemos patikimumą, greitaveiką ir saugumą. Debesų technologijos leidžia lanksčiai plėsti sistemos pajėgumus pagal organizacijos poreikius.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/dokobit.png", 
    href: "https://www.dokobit.com/", 
    alt: "Dokobit", 
    subtitle: "Elektroninio parašo sprendimai",
    description: "Dokobit integracija leidžia VECTICUM vartotojams pasirašyti dokumentus elektroniniu parašu tiesiogiai sistemoje, užtikrinant sklandų ir juridiškai galiojantį dokumentų tvirtinimo procesą.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/finvalda.png", 
    href: "https://finvalda.lt/", 
    alt: "Finvalda", 
    subtitle: "Finansų valdymo sprendimai",
    description: "Finvalda partnerystė leidžia sujungti personalo valdymo ir finansų apskaitos procesus į vientisą sistemą, automatizuojant duomenų srautus tarp VECTICUM ir buhalterinės apskaitos.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/fortevento.png", 
    href: "https://fortevento.lt/", 
    alt: "Fortevento", 
    subtitle: "Verslo konsultacijos",
    description: "Fortevento padeda organizacijoms optimizuoti verslo procesus ir sėkmingai įdiegti VECTICUM sprendimus, užtikrinant sklandų perėjimą prie skaitmeninių darbo metodų.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/marksign.png", 
    href: "https://marksign.lt/", 
    alt: "MarkSign", 
    subtitle: "Elektroninio parašo technologijos",
    description: "MarkSign sprendimai suteikia VECTICUM vartotojams galimybę naudoti kvalifikuotą elektroninį parašą dokumentų tvirtinimui, užtikrinant atitiktį ES reglamentams.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/rivil.png", 
    href: "https://www.rivile.lt/", 
    alt: "Rivilė", 
    subtitle: "Verslo valdymo ir apskaitos sistemos",
    description: "Rivilės verslo valdymo sistemos integracija su VECTICUM leidžia automatizuoti duomenų mainus tarp personalo valdymo ir įmonės apskaitos procesų.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/softera.png", 
    href: "https://www.softera.lt/", 
    alt: "Softera", 
    subtitle: "Programinės įrangos sprendimai",
    description: "Softera – Microsoft Dynamics partneris, kurio integracija su VECTICUM leidžia sujungti ERP ir personalo valdymo procesus į vieną sklandžiai veikiančią ekosistemą.",
    fullText: null,
    benefits: null
  },
  { 
    src: "/media/partners/talentator.png", 
    href: "/talentator-scorm-mokymai/", 
    alt: "TALENTATOR", 
    subtitle: "Interaktyvūs e. mokymai ir SCORM kursai",
    description: "TALENTATOR ir VECTICUM partnerystė leidžia organizacijoms naudoti profesionaliai paruoštus interaktyvius e. mokymus tiesiogiai VECTICUM sistemoje – su pilnu atsekamumu, automatiniais priminimais ir aiškia mokymų statistika.",
    fullText: null,
    benefits: null,
    website: "https://talentator.lt/"
  },
];

const seoTitle = "Klientų atsiliepimai ir sėkmės Istorijos | Vecticum";
const seoDescription = "Sužinokite, kaip Vecticum padeda įmonėms automatizuoti verslo procesus. Peržiūrėkite klientų atsiliepimus ir sėkmės istorijas iš įvairių pramonės šakų";
const seoImageUrl = seoImage; // Optional
---

<MainLayout title={seoTitle} description={seoDescription} image={seoImageUrl}>
  <!-- Hero -->
  <section class="text-center py-20 px-6 bg-gradient-to-b from-white to-[#f4f7fa]">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">Rekomendacijos</h1>
      <p class="text-lg text-gray-600">
        Mūsų klientai ir partneriai dalinasi savo patirtimi naudojantis Vecticum sprendimais
      </p>
    </div>
  </section>

  <!-- Rekomendacijų kortelės -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        recommendations.map((rec) => (
          <article 
            class="group bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-xl transition duration-300 overflow-hidden"
            aria-label={`Rekomendacija iš ${rec.data.title}`}
          >
            <div class="h-48 bg-gray-100 overflow-hidden">
              <img
                src={rec.data.image}
                alt={rec.data.title}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                {rec.data.title}
              </h2>
              <p class="text-gray-600 text-sm mb-4 line-clamp-4">{rec.data.description}</p>              <a href={rec.data.link} class="inline-flex items-center gap-2 text-accent hover:text-accent-dark font-medium mt-auto">
                Skaityti daugiau
                <span class="text-lg" aria-label="Rodyklė dešinėn">></span>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Trumpi atsiliepimai -->
  <section class="bg-gray-50 py-20">
  <div class="max-w-6xl mx-auto px-6 space-y-16">    <div class="flex flex-col md:flex-row items-center gap-8 border-b pb-12">
      <Image src={retal} alt="Retal - PET pakuočių gamintoja" class="w-32 h-auto" />
      <div class="flex-1 text-gray-700 text-lg leading-relaxed">
          <p>Naudojame ir komandiruočių, ir atostogų valdymo programas. Neseniai įsivedėme veiklos vertinimo programą. Pasakysiu, kad „Vecticum“ produktas komandiruočių valdyme mums labai padeda. Business trip sprendimas labai patogus. Čekiuką gali vietoje nufotografuoti. Viskas įkraunama iškart į sistemą. Kelionių agentūra, kuri taip pat turi prieiga prie programos, įkelia savo dokumentus. Tai mums labai palengvina procesą. Planuojame daryti sklaidą ir į kitas mūsų grupės Europoje įmones. Su „Vecticum“ komanda lengva komunikuoti, atsižvelgia į norus, į įmonės specifiką</p>
          <p class="mt-4 text-sm italic">Aušra Čepulienė, <strong>„Retal Industrines“ įmonių grupės, gaminančios PET pakuotes, personalo vadovė</strong></p>
        </div>
      </div>    <div class="flex flex-col md:flex-row items-center gap-8 border-b pb-12">
      <Image src={woodline} alt="Wood Line - baldų ir interjero žaliavų prekyba" class="w-28 h-auto" />
      <div class="flex-1 text-gray-700 text-lg leading-relaxed">
          <p>Mūsų atsiliepimai yra labai geri. Pateisino lūkesčius, sumažėjo popierizmo, paprasta naudoti. Darbuotojai taip pat gerai vertina. Labai palengvina visas biurokratines procedūras.</p>
          <p class="mt-4 text-sm italic">Vaidotas Razminas, <strong>„Wood Line“ (pagrindinė veiklos sritis - didmeninė ir mažmeninė prekyba baldų ir interjero pramonei skirtomis žaliavomis) finansų direktorius</strong></p>
        </div>
      </div>    <div class="flex flex-col md:flex-row items-center gap-8">
      <Image src={bpo} alt="BPO House - buhalterinės apskaitos paslaugos" class="w-28 h-auto" />
      <div class="flex-1 text-gray-700 text-lg leading-relaxed">
          <p>Iki šiol naudojome kitą programą. „Vecticum“ produktą naudoti pradėjome neseniai. Atsiliepiame tik teigiamai. Viskas gerai.</p>
          <p class="mt-4 text-sm italic">Kęstutis Vanagas, <strong>„BPO House“, buhalterinės apskaitos ir kitas finansų valdymo paslaugas, direktorius</strong></p>
        </div>
      </div>
    </div>
  </section>

<!-- Klientų logotipai -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-12">
      Keletas įmonių, naudojančių VECTICUM sprendimus
    </h2>    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-8 items-center justify-center">
      {
        logos.map((logo, index) => {
          const logoNames = [
            'Dussmann Service - paslaugų įmonė',
            'IKI - prekybos tinklas',
            'Civinity - konsultacijų bendrovė',
            'Auto Juta - automobilių prekybos centras',
            'Perlas - tekstilės gamintojas',
            'Vilkyškių pieninė - pieno perdirbimo įmonė',
            'Linas Agro - žemės ūkio bendrovė',
            'Omberg - logistikos įmonė',
            'Modus Group - IT sprendimų bendrovė',
            'Nokia - telekomunikacijų technologijų lyderis',
            'CGates - IT konsultacijų įmonė',
            'CityBee - automobilių dalijimosi platforma',
            'Cargo Go - krovinių pervežimo paslaugos',
            'Air Guru - aviacijos paslaugų teikėjas',
            'Narbutas - baldų gamintojas',
            'Aradas - technologijų sprendimų bendrovė',
            'Garant Group - finansų paslaugų grupė',
            'Alta Medica - medicinos paslaugų centras',
            'Homanit - pramonės įmonė',
            'Retal - PET pakuočių gamintoja',
            'Mana Ranga - drabužių gamyba',
            'Projektana - projektų valdymo sprendimai',
            'BPO - verslo procesų optimizavimas',
            'Neogroup - konsultacijų grupė',
            'Vilniaus švietimas - švietimo paslaugos',
            'Triniti Jurex - teisinių paslaugų bendrovė',
            'Yukon - technologijų sprendimai',
            'Freda - gamybos įmonė',
            'Garant - finansų sprendimai',
            'BNM Finance - finansų paslaugos'
          ];
          return (
            <img
              src={logo.src}
              alt={logoNames[index] || 'Vecticum klientas'}
              class="mx-auto h-auto grayscale opacity-70 hover:opacity-100 hover:grayscale-0 transition duration-300"
            />
          );
        })
      }
    </div>
  </div>
</section>

<!-- Partneriai -->
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
        Įmonės, kurios prisideda prie mūsų sistemos veikimo
      </h2>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        Strateginės partnerystės leidžia pasiūlyti kompleksinius sprendimus, apimančius visą verslo procesų grandinę
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        partner.map((p) => (
          <article class="group bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-300">
            <div class="p-6 sm:p-8">
              {/* Header: logo + pavadinimas */}
              <div class="flex items-center gap-5 mb-5">
                <div class="flex-shrink-0 w-16 h-16 sm:w-20 sm:h-20 bg-gray-50 rounded-xl border border-gray-100 flex items-center justify-center p-3 group-hover:border-blue-100 transition-colors">
                  <img src={p.src} alt={p.alt} class="max-w-full max-h-full object-contain" />
                </div>
                <div class="min-w-0">
                  <h3 class="text-lg font-bold text-gray-900 truncate">{p.alt}</h3>
                  <p class="text-sm text-blue-600 font-medium">{p.subtitle}</p>
                </div>
              </div>

              {/* Trumpas aprašymas */}
              <p class="text-gray-600 text-sm leading-relaxed mb-5">
                {p.description}
              </p>

              {/* Išplėstas turinys – tik jei yra fullText */}
              {p.fullText && (
                <details class="partner-details group/details">
                  <summary class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 cursor-pointer select-none transition-colors list-none [&::-webkit-details-marker]:hidden">
                    <span class="group-open/details:hidden">Skaityti daugiau</span>
                    <span class="hidden group-open/details:inline">Skaityti mažiau</span>
                    <svg class="w-4 h-4 transition-transform group-open/details:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="mt-5 pt-5 border-t border-gray-100 space-y-4 text-sm text-gray-700 leading-relaxed prose prose-sm max-w-none" set:html={p.fullText} />
                  {p.benefits && (
                    <div class="mt-5 bg-blue-50 rounded-xl p-5">
                      <h4 class="text-xs font-semibold uppercase tracking-wide text-gray-900 mb-3">Partnerystės nauda</h4>
                      <ul class="space-y-2">
                        {p.benefits.map((b: string) => (
                          <li class="flex items-start gap-2 text-sm text-gray-700">
                            <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                            {b}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </details>
              )}

              {/* Nuorodos */}
              <div class={`flex items-center gap-4 flex-wrap ${p.fullText ? 'mt-5 pt-5 border-t border-gray-100' : 'mt-2'}`}>
                {p.href.startsWith('/') && (
                  <a href={p.href} class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">
                    Sužinoti daugiau
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                  </a>
                )}
                <a href={p.website || p.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-blue-600 transition-colors">
                  Apsilankyti svetainėje
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

</MainLayout>
