---
import MainLayout from "../layouts/MainLayout.astro";
const seoTitle = "Nemokamas sistemos išbandymas | Vecticum";
const seoDescription = "Išbandykite Vecticum dokumentų ir personalo valdymo sistemą nemokamai. Užsiregistruokite demonstracijai ir sužinokite, kaip sistema gali padėti jūsų įmonei.";
---

<MainLayout title={seoTitle} description={seoDescription}>

<!-- Hero -->
<section class="relative overflow-hidden bg-[#3C7099] py-20 px-4 sm:px-6 lg:px-8">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-white/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>
  
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full text-white/90 text-sm font-medium mb-6">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      Nemokama demonstracija
    </div>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-8">
      Išbandykite VECTICUM sistemą
    </h1>
    <p class="text-lg text-white/80 max-w-2xl mx-auto">
      Pamatykite, kaip Vecticum gali automatizuoti jūsų įmonės procesus. Užpildykite trumpą formą ir gaukite individualią sistemos demonstraciją.
    </p>
  </div>
</section>

<!-- Multi-step Form -->
<section class="py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-[#f4f7fa] to-white">
  <div class="max-w-2xl mx-auto">
    
    <!-- Progress indicator -->
    <div class="mb-10" id="progress-container">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-gray-500" id="step-label">1 žingsnis iš 4</span>
        <span class="text-sm font-medium text-[#C81F6A]" id="progress-percent">25%</span>
      </div>
      <div class="w-full h-2 bg-gray-200 rounded-full overflow-hidden">
        <div class="h-full bg-gradient-to-r from-[#C81F6A] to-[#e84393] rounded-full transition-all duration-500 ease-out" id="progress-bar" style="width: 25%"></div>
      </div>
    </div>

    <!-- Form container -->
    <form id="newsletter-registration-form" class="relative">
      <input type="hidden" name="form_source" value="Leads is nemokamo bandymo (newsletter)" />
      <input type="hidden" name="newsletterConsent" value="false" data-newsletter-consent />
      <!-- Honeypot -->
      <div style="position: absolute; left: -9999px; top: -9999px;">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <!-- STEP 1: Company Size -->
      <div class="step-panel active" data-step="1">
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-10 border border-gray-100">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 bg-[#3C7099]/10 rounded-xl mb-4">
              <svg class="w-7 h-7 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Koks jūsų įmonės dydis?</h2>
            <p class="text-gray-500 mt-2">Tai padės mums parengti tinkamiausią demonstraciją</p>
          </div>
          
          <div class="grid grid-cols-2 gap-3 sm:gap-4" id="company-size-options">
            <button type="button" data-value="1-10" class="size-option group flex flex-col items-center justify-center p-5 sm:p-6 rounded-xl border-2 border-gray-200 hover:border-[#C81F6A] hover:bg-[#C81F6A]/5 transition-all duration-200 cursor-pointer">
              <span class="text-2xl sm:text-3xl font-bold text-gray-800 group-hover:text-[#C81F6A] transition-colors">1–10</span>
              <span class="text-sm text-gray-500 mt-1">darbuotojų</span>
            </button>
            <button type="button" data-value="11-50" class="size-option group flex flex-col items-center justify-center p-5 sm:p-6 rounded-xl border-2 border-gray-200 hover:border-[#C81F6A] hover:bg-[#C81F6A]/5 transition-all duration-200 cursor-pointer">
              <span class="text-2xl sm:text-3xl font-bold text-gray-800 group-hover:text-[#C81F6A] transition-colors">11–50</span>
              <span class="text-sm text-gray-500 mt-1">darbuotojų</span>
            </button>
            <button type="button" data-value="51-200" class="size-option group flex flex-col items-center justify-center p-5 sm:p-6 rounded-xl border-2 border-gray-200 hover:border-[#C81F6A] hover:bg-[#C81F6A]/5 transition-all duration-200 cursor-pointer">
              <span class="text-2xl sm:text-3xl font-bold text-gray-800 group-hover:text-[#C81F6A] transition-colors">51–200</span>
              <span class="text-sm text-gray-500 mt-1">darbuotojų</span>
            </button>
            <button type="button" data-value="200+" class="size-option group flex flex-col items-center justify-center p-5 sm:p-6 rounded-xl border-2 border-gray-200 hover:border-[#C81F6A] hover:bg-[#C81F6A]/5 transition-all duration-200 cursor-pointer">
              <span class="text-2xl sm:text-3xl font-bold text-gray-800 group-hover:text-[#C81F6A] transition-colors">200+</span>
              <span class="text-sm text-gray-500 mt-1">darbuotojų</span>
            </button>
          </div>
          <input type="hidden" name="company_size" id="company-size-input" />
          <p class="text-red-500 text-sm mt-3 hidden" id="size-error">Pasirinkite imones dydi</p>
        </div>
      </div>

      <!-- STEP 2: Solutions -->
      <div class="step-panel" data-step="2">
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-10 border border-gray-100">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 bg-[#C81F6A]/10 rounded-xl mb-4">
              <svg class="w-7 h-7 text-[#C81F6A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Kokie sprendimai jus domina?</h2>
            <p class="text-gray-500 mt-2">Pasirinkite vieną ar kelis (galėsite pakeisti vėliau)</p>
          </div>
          
          <div class="space-y-3" id="solutions-options">
            <button type="button" data-value="Personalo valdymas" class="solution-option w-full flex items-center gap-4 p-4 sm:p-5 rounded-xl border-2 border-gray-200 hover:border-[#3C7099] hover:bg-[#3C7099]/5 transition-all duration-200 cursor-pointer text-left group">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-[#3C7099]/10 flex items-center justify-center group-hover:bg-[#3C7099]/20 transition-colors">
                <svg class="w-6 h-6 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
              </div>
              <div class="flex-1">
                <span class="font-semibold text-gray-800 text-base">Personalo valdymas</span>
                <span class="block text-sm text-gray-500">Atostogos, sutartys, darbuotojų duomenys</span>
              </div>
              <div class="flex-shrink-0 w-6 h-6 rounded-md border-2 border-gray-300 group-hover:border-[#3C7099] flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white scale-0 transition-transform check-icon" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
            </button>
            <button type="button" data-value="Dokumentų valdymas" class="solution-option w-full flex items-center gap-4 p-4 sm:p-5 rounded-xl border-2 border-gray-200 hover:border-[#3C7099] hover:bg-[#3C7099]/5 transition-all duration-200 cursor-pointer text-left group">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-[#3C7099]/10 flex items-center justify-center group-hover:bg-[#3C7099]/20 transition-colors">
                <svg class="w-6 h-6 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
              <div class="flex-1">
                <span class="font-semibold text-gray-800 text-base">Dokumentų valdymas</span>
                <span class="block text-sm text-gray-500">Sutartys, įsakymai, tvirtinimo procesai</span>
              </div>
              <div class="flex-shrink-0 w-6 h-6 rounded-md border-2 border-gray-300 group-hover:border-[#3C7099] flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white scale-0 transition-transform check-icon" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
            </button>
            <button type="button" data-value="Sąskaitų valdymas" class="solution-option w-full flex items-center gap-4 p-4 sm:p-5 rounded-xl border-2 border-gray-200 hover:border-[#3C7099] hover:bg-[#3C7099]/5 transition-all duration-200 cursor-pointer text-left group">
              <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-[#3C7099]/10 flex items-center justify-center group-hover:bg-[#3C7099]/20 transition-colors">
                <svg class="w-6 h-6 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              </div>
              <div class="flex-1">
                <span class="font-semibold text-gray-800 text-base">Sąskaitų valdymas</span>
                <span class="block text-sm text-gray-500">Gaunamų sąskaitų tvirtinimas ir apskaita</span>
              </div>
              <div class="flex-shrink-0 w-6 h-6 rounded-md border-2 border-gray-300 group-hover:border-[#3C7099] flex items-center justify-center transition-colors">
                <svg class="w-4 h-4 text-white scale-0 transition-transform check-icon" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
            </button>
          </div>
          <input type="hidden" name="solutions" id="solutions-input" />
          <p class="text-red-500 text-sm mt-3 hidden" id="solutions-error">Pasirinkite bent vieną sprendimą</p>
          
          <div class="mt-8 flex justify-between">
            <button type="button" class="btn-back flex items-center gap-2 text-gray-500 hover:text-gray-700 font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Atgal
            </button>
            <button type="button" class="btn-next inline-flex items-center gap-2 bg-[#C81F6A] text-white px-6 py-3 rounded-full font-medium hover:bg-[#a51856] transition-colors shadow-md hover:shadow-lg">
              Tęsti
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- STEP 3: Company name -->
      <div class="step-panel" data-step="3">
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-10 border border-gray-100">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 bg-[#3C7099]/10 rounded-xl mb-4">
              <svg class="w-7 h-7 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a2 2 0 012-2h2a2 2 0 012 2v5m-4 0h4"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Jūsų įmonės pavadinimas</h2>
            <p class="text-gray-500 mt-2">Tai padės mums geriau pasiruošti demonstracijai</p>
          </div>
          
          <div class="max-w-md mx-auto">
            <input 
              type="text" 
              name="company" 
              id="company-input"
              placeholder="pvz., UAB Mano imone"
              class="w-full p-4 text-lg border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#C81F6A] transition-colors duration-200 text-center placeholder:text-gray-400"
            />
            <p class="text-red-500 text-sm mt-3 hidden text-center" id="company-error">Iveskite imones pavadinima</p>
          </div>
          
          <div class="mt-8 flex justify-between">
            <button type="button" class="btn-back flex items-center gap-2 text-gray-500 hover:text-gray-700 font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Atgal
            </button>
            <button type="button" class="btn-next inline-flex items-center gap-2 bg-[#C81F6A] text-white px-6 py-3 rounded-full font-medium hover:bg-[#a51856] transition-colors shadow-md hover:shadow-lg">
              Tęsti
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- STEP 4: Email -->
      <div class="step-panel" data-step="4">
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-10 border border-gray-100">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 bg-[#C81F6A]/10 rounded-xl mb-4">
              <svg class="w-7 h-7 text-[#C81F6A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Beveik baigta!</h2>
            <p class="text-gray-500 mt-2">Nurodykite el. paštą ir susisieksime dėl demonstracijos</p>
          </div>
          
          <div class="max-w-md mx-auto">
            <input 
              type="email" 
              name="email" 
              id="email-input"
              placeholder="jusu@imone.lt"
              class="w-full p-4 text-lg border-2 border-gray-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#C81F6A] transition-colors duration-200 text-center placeholder:text-gray-400"
            />
            <p class="text-red-500 text-sm mt-3 hidden text-center" id="email-error">Iveskite teisinga el. pasto adresa</p>
            
            <label for="nl-consent" class="flex items-start gap-3 mt-6 text-sm text-gray-600 leading-relaxed cursor-pointer select-none">
              <input id="nl-consent" type="checkbox" class="mt-0.5 h-5 w-5 rounded border-gray-300 text-[#C81F6A] focus:ring-[#C81F6A] focus:ring-2 focus:ring-offset-0" />
              <span>Noriu gauti naujienas apie Vecticum produktus ir pasiulymus el. pastu.</span>
            </label>
          </div>
          
          <div class="mt-8 flex justify-between">
            <button type="button" class="btn-back flex items-center gap-2 text-gray-500 hover:text-gray-700 font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Atgal
            </button>
            <button type="submit" id="submit-btn" class="inline-flex items-center gap-2 bg-[#C81F6A] text-white px-8 py-3 rounded-full font-medium hover:bg-[#a51856] transition-colors shadow-md hover:shadow-lg">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Registruotis demonstracijai
            </button>
          </div>
        </div>
      </div>

      <!-- SUCCESS STATE -->
      <div class="step-panel" data-step="success">
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-12 border border-gray-100 text-center">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">Ačiū už registraciją!</h2>
          <p class="text-lg text-gray-600 max-w-md mx-auto mb-8">
            Susisieksime su jumis dėl sistemos pristatymo per <strong>2 darbo dienas</strong>.
          </p>
          <div class="bg-[#f4f7fa] rounded-xl p-6 max-w-sm mx-auto">
            <p class="text-sm text-gray-500 mb-1">Jūsų el. paštas</p>
            <p class="font-medium text-gray-800" id="confirmed-email">–</p>
          </div>
        </div>
      </div>
    </form>

    <!-- Trust indicators -->
    <div class="mt-12 text-center" id="trust-indicators">
      <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          35+ sprendimai verslui
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          ISO 27001 saugumo standartas
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#3C7099]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          800+ klientų pasitiki
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .step-panel {
    display: none;
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .step-panel.active {
    display: block;
    opacity: 1;
    transform: translateX(0);
  }
  .step-panel.slide-out-left {
    display: block;
    opacity: 0;
    transform: translateX(-20px);
  }
  .step-panel.slide-in-right {
    display: block;
    opacity: 0;
    transform: translateX(20px);
  }
  .size-option.selected {
    border-color: #C81F6A;
    background-color: rgba(200, 31, 106, 0.05);
    box-shadow: 0 0 0 3px rgba(200, 31, 106, 0.1);
  }
  .size-option.selected span:first-child {
    color: #C81F6A;
  }
  .solution-option.selected {
    border-color: #3C7099;
    background-color: rgba(60, 112, 153, 0.05);
  }
  .solution-option.selected .check-icon {
    transform: scale(1);
  }
  .solution-option.selected > div:last-child {
    background-color: #3C7099;
    border-color: #3C7099;
  }
</style>

<script is:inline>
(function() {
  if (window.newsletterFormInitialized) return;
  window.newsletterFormInitialized = true;

  let currentStep = 1;
  const totalSteps = 4;
  const formData = { company_size: '', solutions: [], company: '', email: '' };

  const form = document.getElementById('newsletter-registration-form');
  const progressBar = document.getElementById('progress-bar');
  const stepLabel = document.getElementById('step-label');
  const progressPercent = document.getElementById('progress-percent');
  const progressContainer = document.getElementById('progress-container');
  const trustIndicators = document.getElementById('trust-indicators');

  function showStep(step) {
    // Hide all panels
    document.querySelectorAll('.step-panel').forEach(panel => {
      panel.classList.remove('active');
    });
    
    // Show target panel
    const target = step === 'success' 
      ? document.querySelector('[data-step="success"]')
      : document.querySelector(`[data-step="${step}"]`);
    
    if (target) {
      setTimeout(() => {
        target.classList.add('active');
      }, 50);
    }

    // Update progress
    if (step === 'success') {
      progressContainer.style.display = 'none';
      trustIndicators.style.display = 'none';
    } else {
      const percent = Math.round((step / totalSteps) * 100);
      progressBar.style.width = percent + '%';
      stepLabel.textContent = step + ' žingsnis iš ' + totalSteps;
      progressPercent.textContent = percent + '%';
    }
  }

  // STEP 1: Company size selection
  document.querySelectorAll('.size-option').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.size-option').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      formData.company_size = btn.dataset.value;
      document.getElementById('company-size-input').value = btn.dataset.value;
      document.getElementById('size-error').classList.add('hidden');
      
      // Auto-advance after short delay
      setTimeout(() => {
        currentStep = 2;
        showStep(2);
      }, 300);
    });
  });

  // STEP 2: Solutions multi-select
  document.querySelectorAll('.solution-option').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('selected');
      const val = btn.dataset.value;
      if (formData.solutions.includes(val)) {
        formData.solutions = formData.solutions.filter(s => s !== val);
      } else {
        formData.solutions.push(val);
      }
      document.getElementById('solutions-input').value = formData.solutions.join(', ');
      document.getElementById('solutions-error').classList.add('hidden');
    });
  });

  // Navigation buttons
  document.querySelectorAll('.btn-next').forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep === 2) {
        if (formData.solutions.length === 0) {
          document.getElementById('solutions-error').classList.remove('hidden');
          return;
        }
        currentStep = 3;
        showStep(3);
        setTimeout(() => document.getElementById('company-input').focus(), 400);
      } else if (currentStep === 3) {
        const company = document.getElementById('company-input').value.trim();
        if (!company) {
          document.getElementById('company-error').classList.remove('hidden');
          return;
        }
        formData.company = company;
        document.getElementById('company-error').classList.add('hidden');
        currentStep = 4;
        showStep(4);
        setTimeout(() => document.getElementById('email-input').focus(), 400);
      }
    });
  });

  document.querySelectorAll('.btn-back').forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        showStep(currentStep);
      }
    });
  });

  // Input clearing errors
  document.getElementById('company-input')?.addEventListener('input', () => {
    document.getElementById('company-error').classList.add('hidden');
  });
  document.getElementById('email-input')?.addEventListener('input', () => {
    document.getElementById('email-error').classList.add('hidden');
  });

  // Newsletter consent sync
  const consentCheckbox = document.getElementById('nl-consent');
  const consentField = form.querySelector('[data-newsletter-consent]');
  consentCheckbox?.addEventListener('change', () => {
    if (consentField) consentField.value = consentCheckbox.checked ? 'true' : 'false';
  });

  // Enter key to advance
  document.getElementById('company-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      document.querySelector('[data-step="3"] .btn-next')?.click();
    }
  });
  document.getElementById('email-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      document.getElementById('submit-btn')?.click();
    }
  });

  // Form submission
  let isSubmitting = false;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isSubmitting) return;

    const email = document.getElementById('email-input').value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email || !emailRegex.test(email)) {
      document.getElementById('email-error').classList.remove('hidden');
      return;
    }
    formData.email = email;

    isSubmitting = true;
    const submitBtn = document.getElementById('submit-btn');
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
      <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      Siunčiama...
    `;

    // Check honeypot
    const honeypot = form.querySelector('[name="website"]');
    if (honeypot && honeypot.value) {
      showStep('success');
      return;
    }

    // Prepare data
    const payload = {
      name: '(Naujienlaiškio registracija)',
      email: formData.email,
      company: formData.company,
      phone: '',
      position: '',
      message: `Įmonės dydis: ${formData.company_size}. Domina: ${formData.solutions.join(', ')}.`,
      source: 'Naujienlaiškio',
      form_source: 'Leads iš nemokamo bandymo (newsletter)',
      newsletterConsent: consentField?.value === 'true'
    };

    // reCAPTCHA
    let recaptchaToken = 'dev-mode-token';
    try {
      if (typeof grecaptcha !== 'undefined') {
        recaptchaToken = await grecaptcha.execute('6LcP6_ArAAAAAGeVnrM_7mlRq2cjrC6l4Xifj0qQ', {action: 'newsletter_registration'});
      }
    } catch (err) {
      console.warn('reCAPTCHA failed:', err);
    }

    try {
      const response = await fetch('/api/crm', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Recaptcha-Token': recaptchaToken
        },
        body: JSON.stringify(payload)
      });

      document.getElementById('confirmed-email').textContent = formData.email;
      showStep('success');
    } catch (error) {
      console.error('Submission error:', error);
      // Still show success - lead was likely received
      document.getElementById('confirmed-email').textContent = formData.email;
      showStep('success');
    } finally {
      isSubmitting = false;
      submitBtn.disabled = false;
    }
  });

  // Initialize
  showStep(1);
})();
</script>

</MainLayout>
